.env
.env.local
.logs/

# Large regenerable data — produced by importing GeoNames + running
# scrapers. Anyone can rebuild these with the import + scrape scripts.
input/raw/
input/us_postal_codes.tsv
input/zip_codes_full.json
output/scrape.log
output/dealers_final.json

# Ignore generic migrations/ dirs (alembic, custom pipeline) BUT
# re-include Django app migrations — those are first-class source
# code that must be in the repo + the Docker image so `manage.py
# migrate` works at container boot.
migrations/
!web/backend/**/migrations/
!web/backend/**/migrations/**
# Hand-authored SQL migrations applied to RDS by psql (not Django).
!schema/migrations/
!schema/migrations/**
db.sqlite3
.DS_Store
# Project-shared Claude Code agents under .claude/agents/ ARE tracked;
# everything else under .claude/ (session state, caches) stays ignored.
# Note: we use .claude/* (not .claude/) so the !.claude/agents/
# negation can re-include the agents subtree.
.claude/*
!.claude/agents/
input/google_api.json
data/*.sqlite
data/*.sqlite-journal
data/secrets/
data/dumps/

# Pycharm folder
.idea/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyc

# C extensions
*.so

