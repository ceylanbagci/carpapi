{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListFleetPrefix",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::carpapi-frontend-183617081338",
      "Condition": {
        "StringLike": { "s3:prefix": ["fleet/*", "fleet/"] }
      }
    },
    {
      "Sid": "ReadFleetStateFiles",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::carpapi-frontend-183617081338/fleet/*"
    },
    {
      "Sid": "WriteFleetQueueMarkers",
      "Effect": "Allow",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::carpapi-frontend-183617081338/fleet/queue/*"
    }
  ]
}
