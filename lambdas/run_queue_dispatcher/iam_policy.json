{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadAndDeleteQueueMarkers",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::carpapi-frontend-183617081338/fleet/queue/*"
    },
    {
      "Sid": "InvokeAgentLambdas",
      "Effect": "Allow",
      "Action": "lambda:InvokeFunction",
      "Resource": "arn:aws:lambda:us-east-1:183617081338:function:carpapi-*"
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:*:*:*"
    }
  ]
}
