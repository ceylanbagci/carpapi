# Local-dev overrides for the Django backend. Copy to .env.local
# (gitignored) and edit; scripts/dev.sh will source it automatically.
#
# Anything not set here falls back to the defaults in
# carpapi_web/settings.py — localhost:5433, role=carpapi.

# ---- Django ----
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=dev-only-change-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,*

# ---- Postgres ----
# Option 1 — point at the LAN Postgres running on a different machine:
#   CARPAPI_DB_HOST=192.168.1.142
#   CARPAPI_DB_PORT=5433
#   CARPAPI_DB_USER=ahu
#   CARPAPI_DB_PASSWORD=<the password set on that box>
#   CARPAPI_DB_NAME=carpapi
#
# Option 2 — local Postgres (matches carpapi/db default):
CARPAPI_DB_HOST=localhost
CARPAPI_DB_PORT=5433
CARPAPI_DB_USER=carpapi
CARPAPI_DB_PASSWORD=carpapi
CARPAPI_DB_NAME=carpapi
