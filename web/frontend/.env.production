# Vite reads this file for `npm run build` (mode=production).
# Build-time substitution — once baked, the URL is hard-coded in the bundle.
# Change here + rebuild + redeploy if the App Runner URL changes.
#
# Custom-domain CNAME → gt3mapscrz.us-east-1.awsapprunner.com.
# Associated 2026-05-15 via `aws apprunner associate-custom-domain`.
VITE_API_BASE=https://api.carpappi.com/api
